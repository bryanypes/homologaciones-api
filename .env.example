# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Homologaciones API
APP_VERSION=1.0.0
DEBUG=false
BASE_URL=http://localhost:8000

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://dev:dev@localhost:5432/homologaciones
DATABASE_URL_ASYNC=postgresql+asyncpg://dev:dev@localhost:5432/homologaciones

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=cambia_esto_por_una_clave_segura_de_al_menos_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=30

# ── OpenAI (análisis de homologación con IA) ──────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Almacenamiento de archivos ────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Correo electrónico (SMTP) ─────────────────────────────────────────────────
# Si no se configura, los correos se omiten silenciosamente
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASSWORD=tu_app_password_de_gmail
EMAIL_FROM=tucorreo@gmail.com

# ── Cloudflare R2 (almacenamiento persistente de archivos) ───────────────────
# Si no se configura, los archivos se guardan en disco local (no persistente en Render)
# Crear cuenta en https://cloudflare.com → R2 → Create bucket
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key
R2_BUCKET_NAME=homologaciones-archivos

# ── Kafka (legado, no se usa activamente) ─────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
