# Base de datos
DATABASE_URL=postgresql://dev:dev@localhost:5432/homologaciones
DATABASE_URL_ASYNC=postgresql+asyncpg://dev:dev@localhost:5432/homologaciones

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generar con: openssl rand -hex 32
SECRET_KEY=cambia_esto
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=30

# OpenAI
OPENAI_API_KEY=sk-...

# Correo — resend.com (gratis hasta 100/día)
# EMAIL_FROM puede ser onboarding@resend.dev mientras no tengas dominio propio
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# Archivos
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
BASE_URL=http://localhost:8000

# Cloudflare R2 — opcional, si no se configura guarda en disco local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=homologaciones-archivos

# Notificación interna cuando aprueban una homologación
MERCADEO_EMAIL=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
