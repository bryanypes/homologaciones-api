# Base de datos
DATABASE_URL=postgresql://dev:dev@localhost:5432/homologaciones
DATABASE_URL_ASYNC=postgresql+asyncpg://dev:dev@localhost:5432/homologaciones

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generar con: openssl rand -hex 32
SECRET_KEY=cambia_esto
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=30

# OpenAI
OPENAI_API_KEY=sk-...

# Correo — brevo.com (gratis 300/día, sin verificar dominio)
# Crear cuenta en brevo.com > SMTP & API > API Keys
BREVO_API_KEY=xkeysib-...
EMAIL_FROM=tucorreo@gmail.com

# Archivos
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
BASE_URL=http://localhost:8000

# Cloudflare R2 — opcional, si no se configura guarda en disco local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=homologaciones-archivos

# Correo interno cuando aprueban una homologación (opcional)
MERCADEO_EMAIL=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
